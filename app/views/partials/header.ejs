<!DOCTYPE html>
<html lang="it" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'WES AI Automation' %></title>
    <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'WES è il workspace operativo che pianifica, usa strumenti autorizzati e consegna risultati verificabili.' %>">
    
    <link rel="stylesheet" href="/css/tailwind.css">
    <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-white text-gray-900 font-sans antialiased">

<% if (typeof success !== 'undefined' && success) { %>
    <div id="successAlert" class="fixed top-4 right-4 z-50 bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg flex items-center gap-2 animate-bounce-in">
        <i class="fas fa-check-circle"></i>
        <span>Operazione completata con successo!</span>
        <button onclick="this.parentElement.remove()" class="ml-2">&times;</button>
    </div>
<% } %>

<% if (typeof error !== 'undefined' && error) { %>
    <div id="errorAlert" class="fixed top-4 right-4 z-50 bg-red-500 text-white px-6 py-3 rounded-lg shadow-lg flex items-center gap-2 animate-bounce-in">
        <i class="fas fa-exclamation-circle"></i>
        <span><%= error %></span>
        <button onclick="this.parentElement.remove()" class="ml-2">&times;</button>
    </div>
<% } %>
