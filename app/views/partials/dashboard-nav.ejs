<%
// Set default page variable to avoid undefined errors
if (typeof page === 'undefined') { page = ''; }
%><!-- Dashboard Sidebar -->
<div class="flex h-screen bg-gray-50">
    <!-- Sidebar -->
    <aside class="w-64 bg-white border-r border-gray-200 flex flex-col">
        <!-- Logo -->
        <div class="p-4 border-b border-gray-100">
            <a href="/dashboard" class="flex items-center gap-2">
                <div class="w-8 h-8 bg-wes-500 rounded-lg flex items-center justify-center">
                    <i class="fas fa-robot text-white text-sm"></i>
                </div>
                <span class="font-bold">WES <span class="text-wes-500">AI</span></span>
            </a>
        </div>
        
        <!-- Navigation -->
        <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
            <% if (typeof adminPage !== 'undefined' && adminPage) { %>
                <div class="px-4 py-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">Pannello Admin</div>
            <% } %>
            <a href="/dashboard" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium <%= page === 'dashboard' ? 'bg-wes-50 text-wes-600' : 'text-gray-600 hover:bg-gray-50' %> transition">
                <i class="fas fa-chart-pie w-5 text-center"></i>
                <span>Dashboard</span>
            </a>
            <a href="/dashboard/lead" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium <%= page === 'leads' ? 'bg-wes-50 text-wes-600' : 'text-gray-600 hover:bg-gray-50' %> transition">
                <i class="fas fa-users w-5 text-center"></i>
                <span>Lead</span>
            </a>
            <a href="/dashboard/conversazioni" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium <%= page === 'conversations' ? 'bg-wes-50 text-wes-600' : 'text-gray-600 hover:bg-gray-50' %> transition">
                <i class="fas fa-comments w-5 text-center"></i>
                <span>Conversazioni</span>
            </a>
            <a href="/dashboard/appuntamenti" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium <%= page === 'appointments' ? 'bg-wes-50 text-wes-600' : 'text-gray-600 hover:bg-gray-50' %> transition">
                <i class="fas fa-calendar w-5 text-center"></i>
                <span>Appuntamenti</span>
            </a>
            <a href="/dashboard/follow-up" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium <%= page === 'followup' ? 'bg-wes-50 text-wes-600' : 'text-gray-600 hover:bg-gray-50' %> transition">
                <i class="fas fa-clock w-5 text-center"></i>
                <span>Follow-up</span>
            </a>
            <a href="/dashboard/preventivi" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium <%= page === 'preventivi' ? 'bg-wes-50 text-wes-600' : 'text-gray-600 hover:bg-gray-50' %> transition">
                <i class="fas fa-file-invoice w-5 text-center"></i>
                <span>Preventivi</span>
            </a>
            
            <hr class="my-3">
            
            <a href="/dashboard/automazioni" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium <%= page === 'automations' ? 'bg-wes-50 text-wes-600' : 'text-gray-600 hover:bg-gray-50' %> transition">
                <i class="fas fa-bolt w-5 text-center"></i>
                <span>Automazioni</span>
            </a>
            <a href="/dashboard/agente" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium <%= page === 'agent' ? 'bg-wes-50 text-wes-600' : 'text-gray-600 hover:bg-gray-50' %> transition">
                <i class="fas fa-robot w-5 text-center"></i>
                <span>Agente AI</span>
            </a>
            <a href="/dashboard/integrazioni" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium <%= page === 'integrations' ? 'bg-wes-50 text-wes-600' : 'text-gray-600 hover:bg-gray-50' %> transition">
                <i class="fas fa-plug w-5 text-center"></i>
                <span>Integrazioni</span>
            </a>
            <a href="/dashboard/statistiche" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium <%= page === 'stats' ? 'bg-wes-50 text-wes-600' : 'text-gray-600 hover:bg-gray-50' %> transition">
                <i class="fas fa-chart-bar w-5 text-center"></i>
                <span>Statistiche</span>
            </a>
            
            <hr class="my-3">
            
            <a href="/dashboard/impostazioni" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium <%= page === 'settings' ? 'bg-wes-50 text-wes-600' : 'text-gray-600 hover:bg-gray-50' %> transition">
                <i class="fas fa-cog w-5 text-center"></i>
                <span>Impostazioni</span>
            </a>
        </nav>
        
        <!-- User info -->
        <div class="p-4 border-t border-gray-100">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-wes-500 rounded-full flex items-center justify-center text-white font-medium">
                    <%= (typeof currentUser !== 'undefined' && currentUser && currentUser.company) ? currentUser.company.charAt(0).toUpperCase() : 'W' %>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium truncate"><%= (typeof currentUser !== 'undefined' && currentUser) ? currentUser.company : 'Utente' %></p>
                    <p class="text-xs text-gray-500 truncate"><%= (typeof currentUser !== 'undefined' && currentUser) ? currentUser.email : '' %></p>
                </div>
                <form action="/auth/logout" method="POST" class="inline">
                    <button type="submit" class="p-2 text-gray-400 hover:text-red-500 transition" title="Esci">
                        <i class="fas fa-sign-out-alt"></i>
                    </button>
                </form>
            </div>
        </div>
    </aside>
    
    <!-- Main content -->
    <main class="flex-1 overflow-y-auto">
        <!-- Top bar -->
        <div class="sticky top-0 bg-white/80 backdrop-blur-sm border-b border-gray-200 px-6 py-4 flex items-center justify-between z-10">
            <div>
                <h1 class="text-xl font-bold text-gray-900"><%= typeof title !== 'undefined' ? title.replace(' - WES AI Automation', '') : 'Dashboard' %></h1>
            </div>
            <div class="flex items-center gap-3">
                <span class="text-xs px-3 py-1 bg-wes-100 text-wes-600 rounded-full font-medium">
                    <%= typeof plan !== 'undefined' ? plan.name + ' - ' + plan.price + '€/mese' : '' %>
                </span>
                <a href="/" class="p-2 text-gray-400 hover:text-wes-500 transition" title="Vai al sito">
                    <i class="fas fa-external-link-alt"></i>
                </a>
            </div>
        </div>
        
        <!-- Page content -->
        <div class="p-6">
