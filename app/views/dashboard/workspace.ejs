<%- include('../partials/header') %>
<%- include('../partials/dashboard-nav') %>

<section class="agent-shell -m-6 min-h-[calc(100vh-73px)] p-6 lg:p-10">
  <div class="mx-auto max-w-6xl">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between mb-10">
      <div>
        <div class="agent-kicker"><span></span> WES Autonomous Intelligence</div>
        <h2 class="agent-title">Cosa vuoi far realizzare?</h2>
        <p class="agent-subtitle">Descrivi il risultato. WES pianifica, usa gli strumenti e porta il lavoro fino alla consegna.</p>
      </div>
      <div class="flex gap-3">
        <div class="agent-stat"><strong><%= counts.running %></strong><span>in corso</span></div>
        <div class="agent-stat"><strong><%= counts.done %></strong><span>completati</span></div>
      </div>
    </div>

    <form id="taskComposer" class="agent-composer" enctype="multipart/form-data">
      <textarea id="taskPrompt" maxlength="8000" placeholder="Esempio: analizza i miei concorrenti, crea una strategia commerciale e consegnami un report con le azioni prioritarie…" required></textarea>
      <div class="agent-mode-switch" role="group" aria-label="Modalità di esecuzione">
        <button type="button" class="active" data-task-mode="autonomous" aria-pressed="true"><i class="fas fa-sparkles"></i><span><b>WES Autonomo</b><small>Un agente, percorso rapido</small></span></button>
        <button type="button" data-task-mode="team" aria-pressed="false"><i class="fas fa-people-group"></i><span><b>Agent Team <em>NEW</em></b><small>Specialisti paralleli + Red Team</small></span></button>
        <input id="taskMode" type="hidden" value="autonomous">
      </div>
      <div id="selectedFiles" class="selected-files hidden"></div>
      <div class="agent-composer-bar">
        <div class="flex gap-2">
          <button type="button" id="attachFiles" class="tool-chip"><i class="fas fa-paperclip"></i> File</button>
          <input id="taskFiles" name="files" type="file" multiple class="hidden" accept=".txt,.md,.csv,.tsv,.json,.pdf,.docx,.xlsx,.pptx,.png,.jpg,.jpeg,.webp">
          <span class="tool-chip tool-chip-static"><i class="fas fa-globe"></i> Web sicuro</span>
          <span class="tool-chip tool-chip-static"><i class="fab fa-python"></i> Python</span>
        </div>
        <button class="run-agent" type="submit"><span>Avvia WES</span><i class="fas fa-arrow-up"></i></button>
      </div>
    </form>

    <div class="project-bar">
      <div><i class="fas fa-folder-tree"></i><select id="taskProject" aria-label="Scegli progetto"><option value="">Task senza progetto</option><% projects.forEach(project => { %><option value="<%= project.id %>"><%= project.name %></option><% }) %></select></div>
      <button id="openProjectModal" type="button"><i class="fas fa-plus"></i> Nuovo progetto</button>
      <span>Il progetto conserva istruzioni, file e memoria tra un task e l’altro.</span>
    </div>

    <div class="prompt-grid mt-5">
      <button data-prompt="Analizza il mercato della mia attività, confronta i 10 concorrenti principali e crea un piano operativo di crescita per i prossimi 90 giorni." data-mode="team"><i class="fas fa-binoculars"></i><span><b>Agent Team Research</b>Più specialisti, una missione</span></button>
      <button data-prompt="Crea una presentazione commerciale completa della mia azienda, con proposta di valore, servizi, prezzi e call to action."><i class="fas fa-presentation-screen"></i><span><b>Presentazione</b>Pitch pronto da vendere</span></button>
      <button data-prompt="Organizza i lead del mio CRM, identifica quelli più promettenti e prepara messaggi di follow-up personalizzati."><i class="fas fa-users-gear"></i><span><b>Sales agent</b>Lavora sui miei lead</span></button>
      <button data-prompt="Crea un sito web moderno e completo per la mia attività, con testi, struttura, SEO e una strategia di conversione."><i class="fas fa-wand-magic-sparkles"></i><span><b>Build</b>Crea un prodotto digitale</span></button>
    </div>

    <div class="schedule-header"><div><h3>Pianificazioni</h3><p>WES può ripetere un lavoro nel momento stabilito.</p></div><button id="openScheduleModal" type="button"><i class="fas fa-calendar-plus"></i> Pianifica task</button></div>
    <div class="schedule-list">
      <% if (!schedules.length) { %><div class="schedule-empty"><i class="fas fa-clock"></i><span>Nessun lavoro ricorrente</span></div><% } %>
      <% schedules.forEach(schedule => { %><div class="schedule-row"><div class="schedule-icon"><i class="fas fa-rotate"></i></div><div><b><%= schedule.name %> <% if (schedule.mode === 'team') { %><span class="team-tag"><i class="fas fa-people-group"></i> Team</span><% } %></b><p><%= schedule.prompt %></p></div><span><i class="fas fa-clock"></i> <%= schedule.next_run ? new Date(schedule.next_run).toLocaleString('it-IT', { dateStyle: 'short', timeStyle: 'short', timeZone: schedule.timezone }) : 'In pausa' %></span><button data-schedule-toggle="<%= schedule.id %>" class="schedule-toggle <%= schedule.is_active ? 'active' : '' %>" aria-label="<%= schedule.is_active ? 'Metti in pausa' : 'Attiva' %>"><i></i></button></div><% }) %>
    </div>

    <div class="flex items-center justify-between mt-12 mb-4">
      <h3 class="text-lg font-semibold text-white">Lavori recenti</h3>
      <span class="text-sm text-slate-500"><%= counts.total %> task totali</span>
    </div>
    <div class="task-list">
      <% if (!tasks.length) { %>
        <div class="empty-tasks"><i class="fas fa-orbit"></i><h4>Il tuo spazio è pronto</h4><p>Il primo lavoro autonomo apparirà qui.</p></div>
      <% } %>
      <% tasks.forEach(task => { %>
        <a href="/workspace/task/<%= task.id %>" class="task-row">
          <div class="task-icon <%= task.status %>"><i class="fas fa-<%= task.status === 'completed' ? 'check' : task.status === 'stopped' ? 'pause' : 'sparkles' %>"></i></div>
          <div class="min-w-0 flex-1"><h4><%= task.title %></h4><p><%= task.prompt %></p></div>
          <div class="task-meta"><% if (task.mode === 'team') { %><span class="team-tag"><i class="fas fa-people-group"></i> Team</span><% } %><% if (task.project_name) { %><span class="project-tag"><%= task.project_name %></span><% } %><span class="status-dot <%= task.status %>"></span><%= task.status === 'completed' ? 'Completato' : task.status === 'stopped' ? 'Interrotto' : task.status === 'failed' ? 'Errore' : task.status === 'waiting_approval' ? 'Da approvare' : task.status === 'waiting_configuration' ? 'Da configurare' : 'In esecuzione' %><i class="fas fa-chevron-right"></i></div>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<div id="projectModal" class="agent-modal hidden" role="dialog" aria-modal="true" aria-labelledby="projectModalTitle">
  <form id="projectForm" class="agent-modal-card">
    <button type="button" id="closeProjectModal" class="modal-close" aria-label="Chiudi">&times;</button>
    <div class="wes-orb"><i class="fas fa-folder-plus"></i></div>
    <h3 id="projectModalTitle">Crea un progetto</h3>
    <p>WES userà queste istruzioni e la memoria dei task futuri.</p>
    <label>Nome<input name="name" maxlength="80" required placeholder="Es. Lancio nuovo prodotto"></label>
    <label>Descrizione<textarea name="description" maxlength="500" placeholder="Obiettivo e contesto del progetto"></textarea></label>
    <label>Istruzioni permanenti<textarea name="instructions" maxlength="5000" placeholder="Tono, regole, pubblico, formati di consegna…"></textarea></label>
    <button type="submit" class="run-agent justify-center"><span>Crea progetto</span><i class="fas fa-check"></i></button>
  </form>
</div>

<div id="scheduleModal" class="agent-modal hidden" role="dialog" aria-modal="true" aria-labelledby="scheduleModalTitle">
  <form id="scheduleForm" class="agent-modal-card">
    <button type="button" data-close-schedule class="modal-close" aria-label="Chiudi">&times;</button>
    <div class="wes-orb"><i class="fas fa-calendar-check"></i></div><h3 id="scheduleModalTitle">Pianifica un task</h3><p>WES creerà una nuova esecuzione con lo stesso obiettivo.</p>
    <label>Nome<input name="name" maxlength="80" required placeholder="Es. Report commerciale del mattino"></label>
    <label>Obiettivo<textarea name="prompt" maxlength="8000" required placeholder="Descrivi cosa deve fare e quale risultato deve consegnare"></textarea></label>
    <div class="schedule-form-grid"><label>Frequenza<select name="frequency"><option value="daily">Ogni giorno</option><option value="weekdays">Dal lunedì al venerdì</option><option value="weekly">Ogni settimana</option></select></label><label>Ora<input name="hour" type="number" value="9" min="0" max="23" required></label><label>Minuti<input name="minute" type="number" value="0" min="0" max="59" required></label><label>Giorno<select name="weekday"><option value="1">Lunedì</option><option value="2">Martedì</option><option value="3">Mercoledì</option><option value="4">Giovedì</option><option value="5">Venerdì</option><option value="6">Sabato</option><option value="0">Domenica</option></select></label></div>
    <input type="hidden" name="timezone" value="Europe/Rome"><input type="hidden" name="project_id" id="scheduleProjectId"><input type="hidden" name="mode" id="scheduleMode" value="autonomous">
    <button type="submit" class="run-agent justify-center"><span>Salva pianificazione</span><i class="fas fa-check"></i></button>
  </form>
</div>
<script src="/js/workspace.js"></script>
        </div></main></div>
<%- include('../partials/footer') %>
