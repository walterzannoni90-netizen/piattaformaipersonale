<%- include('../partials/header') %>
<%- include('../partials/dashboard-nav') %>

<!-- Statistiche generali -->
<div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
    <div class="bg-white rounded-xl border border-gray-100 p-5 text-center">
        <div class="text-2xl font-bold text-wes-500"><%= totalStats.totalLeads.count %></div>
        <div class="text-xs text-gray-500">Lead totali</div>
    </div>
    <div class="bg-white rounded-xl border border-gray-100 p-5 text-center">
        <div class="text-2xl font-bold text-green-500"><%= totalStats.totalConversations.count %></div>
        <div class="text-xs text-gray-500">Conversazioni</div>
    </div>
    <div class="bg-white rounded-xl border border-gray-100 p-5 text-center">
        <div class="text-2xl font-bold text-purple-500"><%= totalStats.totalAppointments.count %></div>
        <div class="text-xs text-gray-500">Appuntamenti</div>
    </div>
    <div class="bg-white rounded-xl border border-gray-100 p-5 text-center">
        <div class="text-2xl font-bold text-amber-500"><%= totalStats.totalFollowUps.count %></div>
        <div class="text-xs text-gray-500">Follow-up</div>
    </div>
    <div class="bg-white rounded-xl border border-gray-100 p-5 text-center">
        <div class="text-2xl font-bold text-blue-500"><%= totalStats.conversionRate %>%</div>
        <div class="text-xs text-gray-500">Tasso conversione</div>
    </div>
</div>

<!-- Usage Chart (last 30 days) -->
<div class="bg-white rounded-xl border border-gray-100 p-6 mb-8">
    <h2 class="font-bold mb-4">Attività Ultimi 30 Giorni</h2>
    <% if (usageStats.length > 0) { %>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-gray-50 text-left text-xs text-gray-500">
                        <th class="px-3 py-2">Data</th>
                        <th class="px-3 py-2">Conversazioni</th>
                        <th class="px-3 py-2">Lead</th>
                        <th class="px-3 py-2">Messaggi</th>
                        <th class="px-3 py-2">Follow-up</th>
                        <th class="px-3 py-2">Appuntamenti</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <% usageStats.forEach(function(stat) { %>
                        <tr class="hover:bg-gray-50">
                            <td class="px-3 py-2"><%= stat.date %></td>
                            <td class="px-3 py-2"><%= stat.conversations_count %></td>
                            <td class="px-3 py-2"><%= stat.leads_count %></td>
                            <td class="px-3 py-2"><%= stat.messages_count %></td>
                            <td class="px-3 py-2"><%= stat.follow_ups_sent %></td>
                            <td class="px-3 py-2"><%= stat.appointments_scheduled %></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <div class="text-center py-8 text-gray-400">
            <i class="fas fa-chart-line text-4xl mb-3 block"></i>
            <p>Non ci sono ancora dati statistici</p>
            <p class="text-xs">Le statistiche verranno generate automaticamente</p>
        </div>
    <% } %>
</div>

<!-- Distribuzioni calcolate dai dati reali del tenant -->
<%
const sourceMeta = {
    whatsapp: { label: 'WhatsApp', icon: 'fab fa-whatsapp', color: 'bg-emerald-500', text: 'text-emerald-500' },
    website: { label: 'Sito web', icon: 'fas fa-globe', color: 'bg-blue-500', text: 'text-blue-500' },
    booking_call: { label: 'Richiesta call', icon: 'fas fa-calendar', color: 'bg-violet-500', text: 'text-violet-500' },
    email: { label: 'Email', icon: 'fas fa-envelope', color: 'bg-purple-500', text: 'text-purple-500' }
};
const statusMeta = {
    new: { label: 'Nuovi', color: 'bg-blue-500' },
    qualified: { label: 'Qualificati', color: 'bg-emerald-500' },
    contacted: { label: 'Contattati', color: 'bg-violet-500' },
    converted: { label: 'Convertiti', color: 'bg-amber-500' },
    lost: { label: 'Persi', color: 'bg-rose-500' }
};
%>
<div class="grid md:grid-cols-2 gap-6">
    <div class="bg-white rounded-xl border border-gray-100 p-6">
        <div class="flex items-start justify-between gap-3 mb-5"><div><h2 class="font-bold">Lead per fonte</h2><p class="text-xs text-gray-400 mt-1">Conteggi registrati nel CRM</p></div><i class="fas fa-fingerprint text-wes-400"></i></div>
        <% if (sourceStats.length) { %><div class="space-y-4">
            <% sourceStats.forEach(function(stat) { const meta = sourceMeta[stat.key] || { label: stat.key, icon: 'fas fa-circle-nodes', color: 'bg-slate-500', text: 'text-slate-500' }; %>
                <div>
                    <div class="flex items-center justify-between mb-1.5"><span class="text-sm flex items-center gap-2 capitalize"><i class="<%= meta.icon %> <%= meta.text %>"></i><%= meta.label %></span><span class="text-xs font-semibold"><%= stat.count %> · <%= stat.percentage %>%</span></div>
                    <div class="bg-gray-100 rounded-full h-2 overflow-hidden"><div class="<%= meta.color %> h-2 rounded-full" style="width: <%= stat.percentage %>%"></div></div>
                </div>
            <% }); %>
        </div><% } else { %><div class="rounded-xl border border-dashed border-gray-200 p-8 text-center text-sm text-gray-400">Nessun lead registrato.</div><% } %>
    </div>

    <div class="bg-white rounded-xl border border-gray-100 p-6">
        <div class="flex items-start justify-between gap-3 mb-5"><div><h2 class="font-bold">Lead per stato</h2><p class="text-xs text-gray-400 mt-1">Pipeline corrente, senza stime</p></div><i class="fas fa-filter text-wes-400"></i></div>
        <% if (statusStats.length) { %><div class="space-y-4">
            <% statusStats.forEach(function(stat) { const meta = statusMeta[stat.key] || { label: stat.key, color: 'bg-slate-500' }; %>
                <div>
                    <div class="flex items-center justify-between mb-1.5"><span class="text-sm capitalize"><%= meta.label %></span><span class="text-xs font-semibold"><%= stat.count %> · <%= stat.percentage %>%</span></div>
                    <div class="bg-gray-100 rounded-full h-2 overflow-hidden"><div class="<%= meta.color %> h-2 rounded-full" style="width: <%= stat.percentage %>%"></div></div>
                </div>
            <% }); %>
        </div><% } else { %><div class="rounded-xl border border-dashed border-gray-200 p-8 text-center text-sm text-gray-400">La pipeline apparirà quando arriveranno i primi lead.</div><% } %>
    </div>
</div>

</main></div>
<%- include('../partials/footer') %>
