<%- include('../partials/header') %>
<%- include('../partials/dashboard-nav') %>

<!-- Active Automations -->
<div class="mb-8">
    <h2 class="font-bold text-lg mb-4">Automazioni Attive</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% if (automations.length > 0) { %>
            <% automations.forEach(function(auto) { %>
                <div class="bg-white rounded-xl border border-gray-100 p-5 hover:shadow-md transition">
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 <%= auto.is_active ? 'bg-green-100' : 'bg-gray-100' %> rounded-xl flex items-center justify-center">
                                <i class="fas fa-bolt <%= auto.is_active ? 'text-green-600' : 'text-gray-400' %>"></i>
                            </div>
                            <div>
                                <h3 class="font-medium text-sm"><%= auto.name %></h3>
                                <p class="text-xs text-gray-400">Trigger: <%= auto.trigger_event %></p>
                            </div>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" class="sr-only peer" 
                                <%= auto.is_active ? 'checked' : '' %>
                                onchange="toggleAutomation('<%= auto.id %>', this.checked)">
                            <div class="w-9 h-5 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-wes-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-wes-500"></div>
                        </label>
                    </div>
                    <div class="flex items-center gap-2 text-xs text-gray-400">
                        <% if (auto.last_run) { %>
                            <i class="fas fa-clock"></i> Ultimo run: <%= new Date(auto.last_run).toLocaleString('it-IT') %>
                        <% } else { %>
                            <span>Mai eseguita</span>
                        <% } %>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="col-span-full text-center py-12 text-gray-400">
                <i class="fas fa-bolt text-4xl mb-3 block"></i>
                <p>Nessuna automazione configurata</p>
            </div>
        <% } %>
    </div>
</div>

<!-- Automation Templates -->
<div>
    <h2 class="font-bold text-lg mb-4">Aggiungi Automazione</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        <% if (typeof templates !== 'undefined' && templates) { %>
            <% templates.forEach(function(tmpl) { %>
                <div class="bg-white rounded-xl border border-gray-100 p-5 hover:shadow-md hover:border-wes-200 transition cursor-pointer group"
                     onclick="createAutomation('<%= tmpl.id %>')">
                    <div class="w-10 h-10 bg-wes-100 rounded-xl flex items-center justify-center mb-3 group-hover:bg-wes-500 transition-colors">
                        <i class="fas fa-<%= tmpl.icon %> text-wes-500 group-hover:text-white transition-colors"></i>
                    </div>
                    <h3 class="font-medium text-sm mb-1"><%= tmpl.name %></h3>
                    <p class="text-xs text-gray-500"><%= tmpl.description %></p>
                </div>
            <% }); %>
        <% } %>
    </div>
</div>

<script>
async function toggleAutomation(id, isActive) {
    await fetch('/api/automation/toggle', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, is_active: isActive })
    });
}

async function createAutomation(templateId) {
    const res = await fetch('/api/automation/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ template_id: templateId })
    });
    const result = await res.json();
    if (result.success) location.reload();
}
</script>

</main></div>
<%- include('../partials/footer') %>
