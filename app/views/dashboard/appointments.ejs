<%- include('../partials/header') %>
<%- include('../partials/dashboard-nav') %>

<div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
    <div class="p-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="font-bold">Appuntamenti (<%= appointments.length %>)</h2>
        <button onclick="alert('Funzionalità di creazione appuntamento in arrivo!')" 
            class="px-4 py-2 bg-wes-500 text-white text-sm font-medium rounded-xl hover:bg-wes-600 transition">
            <i class="fas fa-plus mr-1"></i> Nuovo Appuntamento
        </button>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="bg-gray-50 text-left text-sm text-gray-500">
                    <th class="px-6 py-4 font-medium">Titolo</th>
                    <th class="px-6 py-4 font-medium">Lead</th>
                    <th class="px-6 py-4 font-medium">Data/Ora</th>
                    <th class="px-6 py-4 font-medium">Stato</th>
                    <th class="px-6 py-4 font-medium">Azioni</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                <% if (appointments.length > 0) { %>
                    <% appointments.forEach(function(app) { %>
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-6 py-4 text-sm font-medium"><%= app.title %></td>
                            <td class="px-6 py-4 text-sm"><%= app.lead_name || '-' %></td>
                            <td class="px-6 py-4 text-sm">
                                <%= new Date(app.start_time).toLocaleDateString('it-IT', { weekday: 'short', day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-xs px-2 py-1 rounded-full 
                                    <%= app.status === 'scheduled' ? 'bg-blue-100 text-blue-700' : app.status === 'completed' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                                    <%= app.status === 'scheduled' ? 'Programmato' : app.status === 'completed' ? 'Completato' : 'Cancellato' %>
                                </span>
                            </td>
                            <td class="px-6 py-4">
                                <button class="p-1.5 text-gray-400 hover:text-wes-500 transition"><i class="fas fa-eye"></i></button>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center text-gray-400">
                            <i class="fas fa-calendar text-4xl mb-3 block"></i>
                            <p>Nessun appuntamento</p>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

</main></div>
<%- include('../partials/footer') %>
