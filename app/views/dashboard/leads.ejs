<%- include('../partials/header') %>
<%- include('../partials/dashboard-nav') %>

<!-- Filters -->
<div class="flex flex-wrap items-center gap-3 mb-6">
    <a href="/dashboard/lead" class="px-4 py-2 text-sm font-medium rounded-xl <%= !currentStatus ? 'bg-wes-500 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %> transition">
        Tutti (<%= stats.all.count %>)
    </a>
    <a href="/dashboard/lead?status=new" class="px-4 py-2 text-sm font-medium rounded-xl <%= currentStatus === 'new' ? 'bg-blue-500 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %> transition">
        Nuovi (<%= stats.new.count %>)
    </a>
    <a href="/dashboard/lead?status=qualified" class="px-4 py-2 text-sm font-medium rounded-xl <%= currentStatus === 'qualified' ? 'bg-green-500 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %> transition">
        Qualificati (<%= stats.qualified.count %>)
    </a>
    <a href="/dashboard/lead?status=contacted" class="px-4 py-2 text-sm font-medium rounded-xl <%= currentStatus === 'contacted' ? 'bg-purple-500 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %> transition">
        Contattati (<%= stats.contacted.count %>)
    </a>
    <a href="/dashboard/lead?status=converted" class="px-4 py-2 text-sm font-medium rounded-xl <%= currentStatus === 'converted' ? 'bg-amber-500 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %> transition">
        Convertiti (<%= stats.converted.count %>)
    </a>
    <a href="/dashboard/lead?status=lost" class="px-4 py-2 text-sm font-medium rounded-xl <%= currentStatus === 'lost' ? 'bg-rose-500 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %> transition">
        Persi (<%= stats.lost.count %>)
    </a>
    <button type="button" onclick="document.getElementById('newLeadModal').classList.remove('hidden')" class="ml-auto px-4 py-2 text-sm font-semibold rounded-xl bg-slate-950 text-white hover:bg-violet-700 transition"><i class="fas fa-plus mr-2"></i>Nuovo lead</button>
</div>

<!-- Leads Table -->
<div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="bg-gray-50 text-left text-sm text-gray-500">
                    <th class="px-6 py-4 font-medium">Nome</th>
                    <th class="px-6 py-4 font-medium">Contatto</th>
                    <th class="px-6 py-4 font-medium">Fonte</th>
                    <th class="px-6 py-4 font-medium">Stato</th>
                    <th class="px-6 py-4 font-medium">Score</th>
                    <th class="px-6 py-4 font-medium">Data</th>
                    <th class="px-6 py-4 font-medium">Azioni</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                <% if (leads.length > 0) { %>
                    <% leads.forEach(function(lead) { %>
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 bg-wes-100 rounded-full flex items-center justify-center text-sm font-medium text-wes-600">
                                        <%= lead.name ? lead.name.charAt(0).toUpperCase() : '?' %>
                                    </div>
                                    <span class="font-medium text-sm"><%= lead.name || 'Anonimo' %></span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-sm">
                                <div><%= lead.email || '-' %></div>
                                <div class="text-xs text-gray-400"><%= lead.phone || '' %></div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-xs px-2 py-1 rounded-full 
                                    <%= lead.source === 'whatsapp' ? 'bg-green-100 text-green-700' : lead.source === 'website' ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-600' %>">
                                    <%= lead.source || 'sconosciuto' %>
                                </span>
                            </td>
                            <td class="px-6 py-4">
                                <select onchange="updateLeadStatus('<%= lead.id %>', this.value)" 
                                    class="text-xs px-2 py-1 rounded-full border-0 font-medium cursor-pointer
                                    <%= lead.status === 'qualified' ? 'bg-green-100 text-green-700' : lead.status === 'new' ? 'bg-blue-100 text-blue-700' : lead.status === 'contacted' ? 'bg-purple-100 text-purple-700' : lead.status === 'converted' ? 'bg-amber-100 text-amber-700' : 'bg-gray-100 text-gray-600' %>">
                                    <option value="new" <%= lead.status === 'new' ? 'selected' : '' %>>Nuovo</option>
                                    <option value="qualified" <%= lead.status === 'qualified' ? 'selected' : '' %>>Qualificato</option>
                                    <option value="contacted" <%= lead.status === 'contacted' ? 'selected' : '' %>>Contattato</option>
                                    <option value="converted" <%= lead.status === 'converted' ? 'selected' : '' %>>Convertito</option>
                                </select>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2">
                                    <div class="w-16 bg-gray-200 rounded-full h-1.5">
                                        <div class="bg-wes-500 h-1.5 rounded-full" style="width: <%= lead.score * 10 %>%"></div>
                                    </div>
                                    <span class="text-xs text-gray-500"><%= lead.score %>/10</span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-500">
                                <%= new Date(lead.created_at).toLocaleDateString('it-IT') %>
                            </td>
                            <td class="px-6 py-4">
                                <a href="/dashboard/lead/<%= lead.id %>" class="p-1.5 text-gray-400 hover:text-wes-500 transition" title="Apri scheda" aria-label="Apri scheda lead">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="7" class="px-6 py-12 text-center text-gray-400">
                            <i class="fas fa-inbox text-4xl mb-3 block"></i>
                            <p>Nessun lead trovato</p>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<div id="newLeadModal" class="hidden fixed inset-0 z-50 bg-slate-950/70 backdrop-blur-sm p-4 grid place-items-center">
    <div class="w-full max-w-lg bg-white rounded-3xl border border-slate-200 shadow-2xl p-6 sm:p-8 relative">
        <button type="button" onclick="document.getElementById('newLeadModal').classList.add('hidden')" class="absolute right-5 top-4 text-slate-400 hover:text-slate-950 text-xl" aria-label="Chiudi">&times;</button>
        <div class="w-11 h-11 rounded-xl bg-violet-100 text-violet-600 grid place-items-center"><i class="fas fa-user-plus"></i></div>
        <h2 class="text-2xl font-bold mt-5">Aggiungi un lead</h2><p class="text-sm text-slate-500 mt-1">Basta almeno un recapito. Il record resterà nel tuo workspace.</p>
        <form id="newLeadForm" class="mt-6 grid sm:grid-cols-2 gap-4">
            <label class="text-xs text-slate-500 sm:col-span-2">Nome<input name="name" maxlength="120" class="mt-1.5 w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-violet-500"></label>
            <label class="text-xs text-slate-500">Email<input name="email" type="email" maxlength="254" class="mt-1.5 w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-violet-500"></label>
            <label class="text-xs text-slate-500">Telefono<input name="phone" maxlength="40" class="mt-1.5 w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-violet-500"></label>
            <label class="text-xs text-slate-500 sm:col-span-2">Fonte<select name="source" class="mt-1.5 w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none"><option value="manual">Inserimento manuale</option><option value="website">Sito web</option><option value="whatsapp">WhatsApp</option><option value="email">Email</option><option value="referral">Referral</option></select></label>
            <label class="text-xs text-slate-500 sm:col-span-2">Note<textarea name="notes" maxlength="5000" rows="4" class="mt-1.5 w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-violet-500 resize-none"></textarea></label>
            <button class="sm:col-span-2 rounded-xl bg-slate-950 text-white py-3 text-sm font-bold hover:bg-violet-700 transition">Crea e apri scheda</button>
        </form>
    </div>
</div>

<script>
async function updateLeadStatus(id, status) {
    const response = await fetch('/api/lead/update-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, status })
    });
    const result = await response.json();
    if (result.success) location.reload();
    else showToast(result.error || 'Stato non aggiornato', 'error');
}
document.getElementById('newLeadForm').addEventListener('submit', async function(event) {
    event.preventDefault();
    const result = await apiCall('/api/leads', 'POST', Object.fromEntries(new FormData(this).entries()));
    if (result.success) location.href = result.redirect;
    else showToast(result.error || 'Lead non creato', 'error');
});
</script>

</main></div>
<%- include('../partials/footer') %>
