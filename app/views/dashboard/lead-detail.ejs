<%- include('../partials/header') %>
<%- include('../partials/dashboard-nav') %>

<div class="max-w-6xl mx-auto">
  <a href="/dashboard/lead" class="inline-flex items-center gap-2 text-xs font-semibold text-slate-500 hover:text-violet-600 mb-5"><i class="fas fa-arrow-left"></i>Torna alla pipeline</a>
  <div class="grid lg:grid-cols-[minmax(0,1fr)_340px] gap-6">
    <section class="space-y-6">
      <div class="relative overflow-hidden rounded-3xl bg-[#0c0f17] text-white border border-slate-800 p-7 sm:p-9 shadow-2xl shadow-slate-300/30">
        <div class="absolute -right-16 -top-20 w-64 h-64 rounded-full bg-violet-600/20 blur-3xl"></div>
        <div class="relative flex flex-col sm:flex-row sm:items-start justify-between gap-6">
          <div class="flex items-center gap-4"><div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-violet-500 to-fuchsia-500 grid place-items-center text-xl font-bold"><%= (lead.name || lead.email || '?').charAt(0).toUpperCase() %></div><div><div class="text-[10px] uppercase tracking-[.24em] text-violet-400 font-bold">Lead intelligence</div><h2 class="text-3xl font-semibold mt-1"><%= lead.name || 'Contatto senza nome' %></h2><p class="text-sm text-slate-500 mt-1"><%= lead.email || lead.phone || 'Recapito da completare' %></p></div></div>
          <span class="self-start rounded-full border border-white/10 bg-white/[.06] px-3 py-1.5 text-xs capitalize"><i class="fas fa-circle text-[7px] text-emerald-400 mr-2"></i><%= lead.status %></span>
        </div>
        <div class="relative mt-8 grid grid-cols-2 sm:grid-cols-4 gap-3">
          <div class="rounded-2xl bg-white/[.04] border border-white/[.06] p-4"><b class="text-xl"><%= lead.score %>/10</b><span class="block text-[10px] text-slate-500 mt-1">Score</span></div>
          <div class="rounded-2xl bg-white/[.04] border border-white/[.06] p-4"><b class="text-xl"><%= conversations.length %></b><span class="block text-[10px] text-slate-500 mt-1">Conversazioni</span></div>
          <div class="rounded-2xl bg-white/[.04] border border-white/[.06] p-4"><b class="text-xl"><%= appointments.length %></b><span class="block text-[10px] text-slate-500 mt-1">Appuntamenti</span></div>
          <div class="rounded-2xl bg-white/[.04] border border-white/[.06] p-4"><b class="text-xl"><%= invoices.length %></b><span class="block text-[10px] text-slate-500 mt-1">Preventivi</span></div>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <article class="bg-white rounded-2xl border border-slate-200 p-6"><div class="flex items-center justify-between mb-5"><div><h3 class="font-bold">Conversazioni</h3><p class="text-xs text-slate-400 mt-1">Ultime attività collegate</p></div><i class="fas fa-comments text-violet-500"></i></div><div class="space-y-3">
          <% if (conversations.length) { conversations.forEach(function(item) { %><a href="/dashboard/conversazioni?id=<%= item.id %>" class="flex items-center gap-3 rounded-xl border border-slate-100 p-3 hover:border-violet-200 transition"><span class="w-9 h-9 rounded-lg bg-violet-50 text-violet-600 grid place-items-center"><i class="fas fa-message"></i></span><span class="min-w-0 flex-1"><b class="block text-sm capitalize"><%= item.channel %></b><small class="block text-[10px] text-slate-400"><%= item.messageCount %> messaggi · <%= new Date(item.updated_at).toLocaleDateString('it-IT') %></small></span><i class="fas fa-chevron-right text-[10px] text-slate-300"></i></a><% }); } else { %><p class="text-sm text-slate-400 py-5">Nessuna conversazione collegata.</p><% } %>
        </div></article>
        <article class="bg-white rounded-2xl border border-slate-200 p-6"><div class="flex items-center justify-between mb-5"><div><h3 class="font-bold">Agenda</h3><p class="text-xs text-slate-400 mt-1">Appuntamenti del lead</p></div><i class="fas fa-calendar text-emerald-500"></i></div><div class="space-y-3">
          <% if (appointments.length) { appointments.forEach(function(item) { %><div class="flex items-center gap-3 rounded-xl border border-slate-100 p-3"><span class="w-9 h-9 rounded-lg bg-emerald-50 text-emerald-600 grid place-items-center"><i class="fas fa-calendar-day"></i></span><span class="min-w-0 flex-1"><b class="block text-sm truncate"><%= item.title %></b><small class="block text-[10px] text-slate-400"><%= new Date(item.start_time).toLocaleString('it-IT') %></small></span><span class="text-[9px] uppercase text-slate-400"><%= item.status %></span></div><% }); } else { %><p class="text-sm text-slate-400 py-5">Nessun appuntamento collegato.</p><% } %>
        </div></article>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <article class="bg-white rounded-2xl border border-slate-200 p-6"><h3 class="font-bold mb-4">Follow-up</h3><div class="space-y-2"><% if (followUps.length) { followUps.forEach(function(item) { %><div class="flex justify-between gap-3 text-xs border-b border-slate-100 py-2"><span><%= item.type %> · <%= item.channel %></span><span class="text-slate-400"><%= item.status %> · <%= new Date(item.scheduled_at).toLocaleDateString('it-IT') %></span></div><% }); } else { %><p class="text-sm text-slate-400">Nessun follow-up.</p><% } %></div></article>
        <article class="bg-white rounded-2xl border border-slate-200 p-6"><h3 class="font-bold mb-4">Preventivi</h3><div class="space-y-2"><% if (invoices.length) { invoices.forEach(function(item) { %><div class="flex justify-between gap-3 text-xs border-b border-slate-100 py-2"><span class="font-mono"><%= item.invoice_number %></span><span class="text-slate-500"><%= Number(item.amount).toLocaleString('it-IT', { style: 'currency', currency: 'EUR' }) %> · <%= item.status %></span></div><% }); } else { %><p class="text-sm text-slate-400">Nessun preventivo.</p><% } %></div></article>
      </div>
    </section>

    <aside class="bg-white rounded-2xl border border-slate-200 p-6 h-fit lg:sticky lg:top-28">
      <div class="flex items-center justify-between"><div><h3 class="font-bold">Scheda lead</h3><p class="text-xs text-slate-400 mt-1">Modifiche tracciate nell’audit</p></div><i class="fas fa-user-pen text-violet-500"></i></div>
      <form id="leadEditForm" class="mt-6 space-y-4">
        <label class="block text-xs text-slate-500">Nome<input name="name" maxlength="120" value="<%= lead.name || '' %>" class="mt-1.5 w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm outline-none focus:border-violet-500"></label>
        <label class="block text-xs text-slate-500">Email<input name="email" type="email" maxlength="254" value="<%= lead.email || '' %>" class="mt-1.5 w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm outline-none focus:border-violet-500"></label>
        <label class="block text-xs text-slate-500">Telefono<input name="phone" maxlength="40" value="<%= lead.phone || '' %>" class="mt-1.5 w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm outline-none focus:border-violet-500"></label>
        <div class="grid grid-cols-2 gap-3"><label class="block text-xs text-slate-500">Stato<select name="status" class="mt-1.5 w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm outline-none"><% ['new','qualified','contacted','converted','lost'].forEach(function(status) { %><option value="<%= status %>" <%= lead.status === status ? 'selected' : '' %>><%= status %></option><% }) %></select></label><label class="block text-xs text-slate-500">Score<input name="score" type="number" min="0" max="10" step="1" value="<%= lead.score %>" class="mt-1.5 w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm outline-none"></label></div>
        <label class="block text-xs text-slate-500">Fonte<input name="source" maxlength="40" value="<%= lead.source || 'manual' %>" class="mt-1.5 w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm outline-none focus:border-violet-500"></label>
        <label class="block text-xs text-slate-500">Note<textarea name="notes" maxlength="5000" rows="6" class="mt-1.5 w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm outline-none focus:border-violet-500 resize-none"><%= lead.notes || '' %></textarea></label>
        <button class="w-full rounded-xl bg-slate-950 text-white py-3 text-sm font-bold hover:bg-violet-700 transition"><i class="fas fa-check mr-2"></i>Salva scheda</button>
      </form>
      <div class="mt-5 pt-5 border-t border-slate-100 text-[10px] text-slate-400 space-y-1"><p>ID <span class="font-mono"><%= lead.id %></span></p><p>Creato <%= new Date(lead.created_at).toLocaleString('it-IT') %></p><p>Aggiornato <%= new Date(lead.updated_at).toLocaleString('it-IT') %></p></div>
    </aside>
  </div>
</div>

<script>
document.getElementById('leadEditForm').addEventListener('submit', async function(event) {
  event.preventDefault();
  const form = new FormData(this);
  const result = await apiCall('/api/leads/<%= lead.id %>/update', 'POST', Object.fromEntries(form.entries()));
  if (result.success) { showToast('Scheda lead aggiornata'); location.reload(); }
  else showToast(result.error || 'Aggiornamento non riuscito', 'error');
});
</script>

</main></div>
<%- include('../partials/footer') %>
