<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<main class="product-page min-h-[calc(100vh-64px)] grid lg:grid-cols-[.8fr_1.2fr]">
  <section class="hidden lg:flex relative overflow-hidden items-end p-14 border-r border-slate-800 bg-[radial-gradient(circle_at_20%_20%,rgba(48,195,174,.18),transparent_40%)]"><div class="home-grid"></div><div class="relative"><div class="home-badge"><span></span> Inizia in sicurezza</div><h1 class="text-6xl leading-[.95] tracking-[-.06em] font-semibold mt-6">Il tuo agente.<br><span class="text-emerald-300">Le tue regole.</span></h1><p class="text-slate-400 leading-relaxed mt-6 max-w-lg">Crea il workspace, collega solo gli strumenti necessari e mantieni il controllo sulle azioni sensibili.</p><ul class="mt-9 space-y-3 text-sm text-slate-400"><li><i class="fas fa-check text-emerald-400 mr-3"></i>Nessuna carta richiesta nel modulo</li><li><i class="fas fa-check text-emerald-400 mr-3"></i>Chiavi esterne cifrate</li><li><i class="fas fa-check text-emerald-400 mr-3"></i>Python limitato e file privati</li></ul></div></section>
  <section class="flex items-center p-6 sm:p-12 lg:p-16"><div class="w-full max-w-2xl mx-auto"><div class="mb-8"><div class="text-[10px] uppercase tracking-[.22em] text-emerald-300 font-bold">Nuovo workspace</div><h2 class="text-4xl font-semibold tracking-tight mt-3">Costruisci la tua base operativa.</h2><p class="text-sm text-slate-500 mt-2">Potrai configurare modello e connettori dopo l’accesso.</p></div>
    <% if (typeof error !== 'undefined' && error) { %><div class="rounded-xl bg-rose-500/10 border border-rose-500/20 text-rose-200 px-4 py-3 text-sm mb-5"><i class="fas fa-circle-exclamation mr-2"></i><%= error %></div><% } %>
    <form action="/auth/register" method="POST" class="space-y-4">
      <div class="grid sm:grid-cols-2 gap-4"><label class="text-xs text-slate-400">Azienda *<input name="company_name" required minlength="2" maxlength="120" autocomplete="organization" class="mt-2 w-full rounded-xl bg-slate-900 border border-slate-700 px-4 py-3.5 text-sm text-white outline-none focus:border-emerald-500" placeholder="Nome azienda"></label><label class="text-xs text-slate-400">Settore<select name="sector" class="mt-2 w-full rounded-xl bg-slate-900 border border-slate-700 px-4 py-3.5 text-sm text-white outline-none focus:border-emerald-500"><option value="">Seleziona</option><option>Immobiliare</option><option>Automotive</option><option value="Servizi">Servizi professionali</option><option>E-commerce</option><option>Sanità</option><option>Finanza</option><option>Istruzione</option><option>Tecnologia</option><option>Altro</option></select></label></div>
      <div class="grid sm:grid-cols-2 gap-4"><label class="text-xs text-slate-400">Email *<input name="email" type="email" required maxlength="254" autocomplete="email" class="mt-2 w-full rounded-xl bg-slate-900 border border-slate-700 px-4 py-3.5 text-sm text-white outline-none focus:border-emerald-500" placeholder="nome@azienda.it"></label><label class="text-xs text-slate-400">Telefono<input name="phone" type="tel" maxlength="40" autocomplete="tel" class="mt-2 w-full rounded-xl bg-slate-900 border border-slate-700 px-4 py-3.5 text-sm text-white outline-none focus:border-emerald-500" placeholder="+39 …"></label></div>
      <label class="block text-xs text-slate-400">Password *<input name="password" type="password" required minlength="10" maxlength="128" autocomplete="new-password" class="mt-2 w-full rounded-xl bg-slate-900 border border-slate-700 px-4 py-3.5 text-sm text-white outline-none focus:border-emerald-500" placeholder="Almeno 10 caratteri"><span class="block mt-2 text-[10px] text-slate-600">Usa una password unica e lunga. Non verrà mai mostrata o inviata via email.</span></label>
      <button class="w-full rounded-xl bg-white text-slate-950 py-3.5 text-sm font-bold hover:bg-emerald-100 transition">Crea workspace <i class="fas fa-arrow-right ml-2"></i></button>
      <p class="text-[10px] text-slate-600 leading-relaxed">Creando l’account accetti i <a href="/termini" class="text-slate-400 underline">termini di servizio</a> e dichiari di aver letto l’<a href="/privacy" class="text-slate-400 underline">informativa privacy</a>.</p>
    </form>
    <p class="mt-6 text-center text-sm text-slate-500">Hai già un account? <a href="/login" class="text-emerald-300 font-medium hover:text-white">Accedi</a></p>
  </div></section>
</main>

<%- include('../partials/footer') %>
