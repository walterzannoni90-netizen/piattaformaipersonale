<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="product-page min-h-[calc(100vh-64px)] flex items-center py-16"><div class="w-full max-w-md mx-auto px-4"><div class="rounded-3xl border border-slate-800 bg-slate-900 p-7 sm:p-9 shadow-2xl"><div class="w-12 h-12 rounded-2xl bg-violet-500/15 text-violet-300 grid place-items-center"><i class="fas fa-key"></i></div><h1 class="text-3xl font-semibold mt-6">Recupera l’accesso.</h1><p class="text-sm text-slate-500 mt-2 leading-relaxed">Inserisci l’email dell’account. Se esiste e il servizio email è disponibile, riceverai un link valido per 30 minuti.</p>
  <% if (submitted) { %><div class="mt-6 rounded-xl bg-emerald-500/10 border border-emerald-500/20 p-4 text-sm text-emerald-200"><i class="fas fa-check-circle mr-2"></i>Richiesta elaborata. Controlla anche la cartella spam.</div><a href="/login" class="mt-5 flex justify-center text-sm text-violet-300">Torna all’accesso</a><% } else { %>
  <form action="/auth/password-dimenticata" method="POST" class="mt-7 space-y-4"><label class="block text-xs text-slate-400">Email<input name="email" type="email" required maxlength="254" autocomplete="email" class="mt-2 w-full rounded-xl bg-slate-950 border border-slate-700 px-4 py-3.5 text-sm text-white outline-none focus:border-violet-500"></label><button class="w-full rounded-xl bg-white text-slate-950 py-3.5 text-sm font-bold">Invia link sicuro</button></form><a href="/login" class="mt-5 flex justify-center text-sm text-slate-500 hover:text-white">Annulla</a><% } %>
</div></div></main>
<%- include('../partials/footer') %>
