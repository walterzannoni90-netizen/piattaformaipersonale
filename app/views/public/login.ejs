<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<section class="min-h-[80vh] flex items-center py-20 bg-gradient-to-br from-wes-50 to-white">
    <div class="max-w-md mx-auto px-4 w-full">
        <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-8">
            <div class="text-center mb-8">
                <div class="w-16 h-16 bg-wes-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-lock text-2xl text-wes-500"></i>
                </div>
                <h1 class="text-2xl font-bold">Accedi</h1>
                <p class="text-gray-500 text-sm mt-1">Inserisci le tue credenziali per accedere alla dashboard</p>
            </div>
            
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm mb-6">
                    <i class="fas fa-exclamation-circle mr-2"></i><%= error %>
                </div>
            <% } %>
            
            <form action="/auth/login" method="POST" class="space-y-4">
                <% if (typeof redirect !== 'undefined' && redirect) { %>
                    <input type="hidden" name="redirect" value="<%= redirect %>">
                <% } %>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <input type="email" name="email" required 
                        class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-wes-500 focus:border-wes-500 outline-none transition"
                        placeholder="tua@email.com">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                    <input type="password" name="password" required 
                        class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-wes-500 focus:border-wes-500 outline-none transition"
                        placeholder="••••••••">
                </div>
                <button type="submit" 
                    class="w-full py-3 px-6 bg-wes-500 text-white font-semibold rounded-xl hover:bg-wes-600 transition shadow-lg shadow-wes-500/20">
                    <i class="fas fa-sign-in-alt mr-2"></i>Accedi
                </button>
            </form>
            
            <div class="mt-6 text-center text-sm text-gray-500">
                Non hai un account? 
                <a href="/register" class="text-wes-500 font-medium hover:text-wes-600">Registrati</a>
            </div>
            
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
