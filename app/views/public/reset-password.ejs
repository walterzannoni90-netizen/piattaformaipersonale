<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="product-page min-h-[calc(100vh-64px)] flex items-center py-16"><div class="w-full max-w-md mx-auto px-4"><div class="rounded-3xl border border-slate-800 bg-slate-900 p-7 sm:p-9 shadow-2xl"><div class="w-12 h-12 rounded-2xl bg-emerald-500/15 text-emerald-300 grid place-items-center"><i class="fas fa-shield-keyhole"></i></div><h1 class="text-3xl font-semibold mt-6">Scegli una nuova password.</h1>
  <% if (error) { %><div class="mt-5 rounded-xl bg-rose-500/10 border border-rose-500/20 p-4 text-sm text-rose-200"><%= error %></div><% } %>
  <% if (valid) { %><form action="/auth/reset-password" method="POST" class="mt-7 space-y-4"><input type="hidden" name="token" value="<%= token %>"><label class="block text-xs text-slate-400">Nuova password<input name="password" type="password" required minlength="10" maxlength="128" autocomplete="new-password" class="mt-2 w-full rounded-xl bg-slate-950 border border-slate-700 px-4 py-3.5 text-sm text-white outline-none focus:border-emerald-500"></label><label class="block text-xs text-slate-400">Ripeti password<input name="password_confirmation" type="password" required minlength="10" maxlength="128" autocomplete="new-password" class="mt-2 w-full rounded-xl bg-slate-950 border border-slate-700 px-4 py-3.5 text-sm text-white outline-none focus:border-emerald-500"></label><button class="w-full rounded-xl bg-white text-slate-950 py-3.5 text-sm font-bold">Aggiorna password</button></form><% } else { %><a href="/password-dimenticata" class="mt-6 flex justify-center rounded-xl bg-white text-slate-950 py-3 text-sm font-bold">Richiedi un nuovo link</a><% } %>
</div></div></main>
<%- include('../partials/footer') %>
