<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<main class="product-page">
  <section class="min-h-[calc(100vh-64px)] grid lg:grid-cols-2">
    <div class="relative overflow-hidden flex items-center p-6 sm:p-12 lg:p-20 border-b lg:border-b-0 lg:border-r border-slate-800"><div class="home-grid"></div><div class="absolute w-96 h-96 rounded-full bg-violet-600/20 blur-[100px] -top-24 -left-24"></div><div class="relative max-w-xl"><div class="home-badge"><span></span> Parliamone sul concreto</div><h1 class="text-5xl lg:text-7xl leading-[.95] tracking-[-.06em] font-semibold mt-5">Hai un processo<br><span class="text-violet-300">da trasformare?</span></h1><p class="text-slate-400 leading-relaxed mt-6">Raccontaci obiettivo, dati disponibili e vincoli. La richiesta viene registrata in modo sicuro e il team potrà valutarne fattibilità e configurazione.</p><div class="grid gap-4 mt-10">
      <a href="mailto:<%= contactEmail %>" class="flex items-center gap-4 rounded-2xl border border-slate-800 bg-slate-900/70 p-4 hover:border-violet-500/50 transition"><span class="w-11 h-11 rounded-xl bg-violet-500/15 text-violet-300 grid place-items-center"><i class="fas fa-envelope"></i></span><span><small class="block text-slate-600 text-[10px] uppercase tracking-widest">Email</small><b class="text-sm"><%= contactEmail %></b></span></a>
      <% if (contactPhone) { %><a href="tel:<%= contactPhone %>" class="flex items-center gap-4 rounded-2xl border border-slate-800 bg-slate-900/70 p-4 hover:border-violet-500/50 transition"><span class="w-11 h-11 rounded-xl bg-cyan-500/15 text-cyan-300 grid place-items-center"><i class="fas fa-phone"></i></span><span><small class="block text-slate-600 text-[10px] uppercase tracking-widest">Telefono</small><b class="text-sm"><%= contactPhone %></b></span></a><% } %>
      <% if (contactLocation) { %><div class="flex items-center gap-4 rounded-2xl border border-slate-800 bg-slate-900/70 p-4"><span class="w-11 h-11 rounded-xl bg-emerald-500/15 text-emerald-300 grid place-items-center"><i class="fas fa-location-dot"></i></span><span><small class="block text-slate-600 text-[10px] uppercase tracking-widest">Sede</small><b class="text-sm"><%= contactLocation %></b></span></div><% } %>
    </div></div></div>

    <div class="flex items-center p-6 sm:p-12 lg:p-20 bg-slate-950"><div class="w-full max-w-xl mx-auto"><div class="mb-8"><div class="text-xs text-violet-300 font-semibold">01 / CONTATTO</div><h2 class="text-3xl font-semibold mt-2">Descrivi ciò che vuoi ottenere.</h2><p class="text-sm text-slate-500 mt-2">I campi contrassegnati sono necessari per gestire la richiesta.</p></div>
      <form action="/contatti" method="POST" class="space-y-4">
        <div class="absolute -left-[9999px]" aria-hidden="true"><label>Website<input type="text" name="website" tabindex="-1" autocomplete="off"></label></div>
        <div class="grid sm:grid-cols-2 gap-4"><label class="text-xs text-slate-400">Nome *<input name="name" required minlength="2" maxlength="120" autocomplete="name" class="mt-2 w-full rounded-xl bg-slate-900 border border-slate-700 px-4 py-3 text-sm text-white outline-none focus:border-violet-500"></label><label class="text-xs text-slate-400">Telefono<input name="phone" type="tel" maxlength="40" autocomplete="tel" class="mt-2 w-full rounded-xl bg-slate-900 border border-slate-700 px-4 py-3 text-sm text-white outline-none focus:border-violet-500"></label></div>
        <label class="block text-xs text-slate-400">Email *<input name="email" type="email" required maxlength="254" autocomplete="email" class="mt-2 w-full rounded-xl bg-slate-900 border border-slate-700 px-4 py-3 text-sm text-white outline-none focus:border-violet-500"></label>
        <label class="block text-xs text-slate-400">Obiettivo *<textarea name="message" rows="7" required minlength="10" maxlength="5000" class="mt-2 w-full rounded-xl bg-slate-900 border border-slate-700 px-4 py-3 text-sm text-white outline-none focus:border-violet-500 resize-none" placeholder="Processo attuale, risultato desiderato, strumenti già usati…"></textarea></label>
        <button class="w-full rounded-xl bg-white text-slate-950 py-3.5 text-sm font-bold hover:bg-violet-100 transition">Invia richiesta <i class="fas fa-arrow-right ml-2"></i></button>
        <p class="text-[10px] text-slate-600 leading-relaxed">Inviando il modulo dichiari di aver letto l’<a href="/privacy" class="text-slate-400 underline">informativa privacy</a>. Nessuna iscrizione marketing automatica.</p>
      </form>
    </div></div>
  </section>
</main>

<%- include('../partials/footer') %>
